SUB2API_BASE_URL=https://your-sub2api-domain.com/api/v1
SUB2API_ADMIN_API_KEY=admin-xxxx
DATABASE_URL=postgresql://user:password@localhost:5432/sub2api

IMAGE_API_URL=https://your-sub2api-domain.com/v1/images/generations
IMAGE_EDIT_API_URL=https://your-sub2api-domain.com/v1/images/edits
IMAGE_EDIT_FIELD_NAME=image[]
IMAGE_API_KEY=sk-xxx
REQUEST_TIMEOUT_SECONDS=360
CORS_ORIGINS=["http://localhost:5173"]

# sub2api ops error webhook 签名验证（留空则不验签）
OPS_WEBHOOK_SECRET=

# Anthropic SDK（用于 LLM 错误规则判断）
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 飞书 Bot DM 通知
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
